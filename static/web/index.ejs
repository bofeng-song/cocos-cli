<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width,user-scalable=no,initial-scale=1,minimum-scale=1,maximum-scale=1,viewport-fit=cover"/>
    <meta name="apple-mobile-web-app-capable" content="yes"/>
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="format-detection" content="telephone=no">
    <meta name="renderer" content="webkit"/>
    <meta name="force-rendering" content="webkit"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1"/>
    <meta name="msapplication-tap-highlight" content="no">
    <meta name="full-screen" content="yes"/>
    <meta name="x5-fullscreen" content="true"/>
    <meta name="360-fullscreen" content="true"/>
    <meta name="screen-orientation" content=""/>
    <meta name="x5-orientation" content="">
    <meta name="x5-page-mode" content="app">
    <style>
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #333;
        }
        #GameCanvas {
            width: 100%;
            height: 100%;
        }
    </style>
</head>
<body>
    <div id="GameDiv" class="wrapper">
        <div id="Cocos3dGameContainer">
            <canvas id="GameCanvas" tabindex="-1" style="background-color: '';"></canvas>
        </div>
    </div>

    <script src="/static/web/polyfills.bundle.js" charset="utf-8"></script>
    
    <!-- SystemJS support. -->
    <script src="/scripting/systemjs/system.js"></script>
    <script src="/scripting/systemjs/extras/named-register.js"></script>

    <!-- Import map that map the engine feature unit modules. -->
    <script src="<%= engineDistPath %>/import-map.json" type="systemjs-importmap"></script>

    <!-- Import map that map the entry of project module(s). -->
    <script type="systemjs-importmap" src="<%= packImportMapURL %>"></script>

    <!-- Import map that map 'cc', 'cc/env'. -->
    <script type="systemjs-importmap">
        <%- JSON.stringify(globalImportMap) %>
    </script>
    
    <!-- Setup the detailed resolution. -->
    <script>
        System.setResolutionDetailMapCallback(function() {
            var url = new URL('<%=packResolutionDetailMapURL%>', window.location);
            return fetch(url).then(function (response) {
                return response.json();
            }).then(function (json) {
                return { json, url: url.href };
            });
        });
    </script>

    <!-- Set CC_EDITOR before engine loads so that editor-only code paths
         (e.g. deserialize._macros) are enabled in the preview.
         Also provide an EditorExtends stub so the engine can reference it
         during class registration. The real implementation is loaded later
         by scene-bundle.js and overwrites this stub. -->
    <script src="/static/web/editor-stub-preload.js"></script>>

    <script src="<%= engineDistPath %>/bundled/index.js"></script>

    <script type="module">
        // Save our resolve hook AND the System instance before scene-bundle overrides them.
        // scene-bundle replaces globalThis.System with a new instance lacking registerRegistry.
        const _originalSystem = System;

        (async function() {
            const serverURL = '<%= serverURL %>';

            try {
                // Wait for async resolution to settle
                await new Promise(resolve => setTimeout(resolve, 500));
                console.log('[Scene] loading scene bundle');
                const SceneBundle = await System.import('/static/web/scene-bundle.js?t=' + Date.now());
                const { startup } = SceneBundle;

                // scene-bundle replaces globalThis.System with a new SystemJS
                // instance that has its own registry, import maps, and closures.
                // This causes all sorts of problems: registrations go to the
                // wrong System, getRegister reads the wrong closure, external
                // modules lose their exports, physics deps don't load, etc.
                //
                // Fix: restore the original System. All engine modules were
                // registered on _originalSystem (via bundled/index.js), all
                // import maps are on _originalSystem, and its getRegister
                // closure matches its register. One System = no bridging needed.
                globalThis.System = _originalSystem;

                const sceneListPromise = await fetch(`${serverURL}/query-asset-infos/cc.SceneAsset`);
                const sceneList = await sceneListPromise.json();
                const length = sceneList.length;
                let sceneUuid = null;
                for (let i = 0; i < length; i++) {
                    const source =  sceneList[i].source;
                    if (source.startsWith('db://internal')) {
                        continue;
                    }
                    sceneUuid =  sceneList[i].uuid;
                    break;
                }
                const startScenePromise = await fetch(`${serverURL}/scene/${sceneUuid}.json`);
                const startScene = await startScenePromise.json();
                await startup({
                    enginePath: '<%= enginePath %>',
                    projectPath: '<%= projectPath %>',
                    serverURL: serverURL,
                    startScene: startScene
                });

                console.log('Cocos Engine and Scene Services loaded successfully');

            } catch (err) {
                console.error('Failed to load Cocos Engine or Services:', err.stack || err);
            }
        })();
    </script>
</body>
</html>
